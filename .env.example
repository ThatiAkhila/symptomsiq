## SymptomIQ environment variables (Vite)
#
# Copy this file to `.env.local` and fill in values.
# IMPORTANT: `.env.local` should NOT be committed.
#
# Vite only exposes variables prefixed with `VITE_` to the browser.

VITE_OPENAI_API_KEY="your_gemini_api_key_here"

# Optional override (defaults to gemini-flash-latest)
VITE_GEMINI_MODEL="gemini-flash-latest"

